# App
APP_NAME=PrepNest AI Tutor Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional: allow dynamic preview deployments (e.g., Vercel preview domains)
# Example: ^https://prepnest(-[a-z0-9-]+)?\.vercel\.app$
CORS_ORIGIN_REGEX=

# Databases
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/prepnest_ai_tutor
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=1440

# Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=PrepNest
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=8
SMTP_MAX_RETRIES=2
SMTP_RETRY_BACKOFF_SECONDS=0.5
SMTP_SSL_FALLBACK_PORT=465
SMTP_ALLOW_SSL_FALLBACK=true

# Email provider transport
# Use auto (default) to prefer Resend when RESEND_API_KEY is set, otherwise SMTP.
EMAIL_PROVIDER=auto
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_API_BASE_URL=https://api.resend.com/emails

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Vector Store
VECTOR_STORE_PATH=./data/vector_store
VECTOR_DIM=384
RETRIEVAL_TOP_K=5

# File Storage
FILE_STORAGE_MODE=local
LOCAL_UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=30

# Optional S3
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
ENABLE_CELERY_INGESTION=false

# Live data controls
LIVE_DATA_TTL_SECONDS=600
LIVE_DATA_RATE_LIMIT_PER_MINUTE=30

# Personalization default
DEFAULT_LEARNING_LEVEL=intermediate
